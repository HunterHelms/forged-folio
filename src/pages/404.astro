---
import Base from '../layouts/Base.astro'
---

<Base title="404 — nothing forged here" description="Page not found.">
  <main class="lost">
    <p class="mono-label">404</p>
    <h1>
      <span class="display">Nothing</span>
      <span class="display-italic heat-text">forged</span>
      <span class="display">here.</span>
    </h1>
    <a href="/">← Back to the furnace</a>
  </main>
</Base>

<style>
  .lost {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    text-align: center;
    padding-inline: var(--gutter);
  }
  .lost h1 {
    font-size: clamp(2.4rem, 8vw, 5rem);
    display: flex;
    align-items: baseline;
    gap: 0.3em;
    flex-wrap: wrap;
    justify-content: center;
  }
  .lost a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
